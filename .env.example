# ── Required: AI Scoring ──────────────────────────────────────────────────
GROQ_API_KEY_1=PASTE_YOUR_GROQ_KEY_HERE
# GROQ_API_KEY_2=PASTE_SECOND_GROQ_KEY_FOR_HIGHER_QUOTA
# GROQ_API_KEY_3=PASTE_THIRD_GROQ_KEY_OPTIONAL
# Get free keys at: https://console.groq.com
# Each key provides 14,400 requests/day (add more for higher throughput).

# ── Required: India/Google Jobs Layer ─────────────────────────────────────
SERPER_API_KEY=PASTE_YOUR_SERPER_KEY_HERE
# Get free key at: https://serper.dev (2,500 searches/month free)

# ── Optional: Serper fallback ─────────────────────────────────────────────
SERPAPI_KEY=PASTE_YOUR_SERPAPI_KEY_HERE
# Get free key at: https://serpapi.com (100 searches/month free)

# ── Optional: Telemetry (helps improve scoring for all users) ─────────────
# TELEMETRY_OPT_IN=true
# Set to true to share anonymous aggregate patterns (no PII, no resume text)

# ── Do not add ────────────────────────────────────────────────────────────
# NAUKRI_COOKIES — deprecated, not needed
